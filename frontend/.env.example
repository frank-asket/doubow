# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Must match how you open the site in the browser (same hostname + port).
# Mixing localhost and 127.0.0.1 counts as different sites for cookies and breaks Clerk redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# If Chrome logs: "Unsafe attempt to load URL http://localhost:3000/... from frame chrome-error://chromewebdata/"
# the usual causes are: (1) Next dev server not running or wrong port, (2) opening 127.0.0.1 while this URL uses localhost,
# or (3) Clerk Dashboard Paths / OAuth redirect URIs omit your exact dev origin — fix the failed load first, then align origins.

# ── Clerk (required for /auth/sign-in and /auth/sign-up) ──────────────────
# Dashboard: https://dashboard.clerk.com → API Keys → Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Server-only; keep out of client bundles. Used by Next.js / Clerk backend.
CLERK_SECRET_KEY=sk_test_...
# Deprecated in middleware (was blocking sidebar routes for accounts without Clerk billing metadata).
# Enforce plans on the backend API instead.
# CLERK_REQUIRE_ACTIVE_SUBSCRIPTION=false
# Dashboard sidebar plan label reads publicMetadata:
# - plan ("free"|"pro"|"business"), or planTier ("pro_monthly"|"business_yearly"), or
# - stripePriceId mapped via JSON (when Billing only sends price IDs):
# NEXT_PUBLIC_PLAN_PRICE_LABELS={"price_abc":"Pro","price_xyz":"Business"}

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-32-chars-minimum
NEXTAUTH_URL=http://localhost:3000

# ── OAuth ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── AI (used in demo artifact directly; move to backend in prod) ───────────
NEXT_PUBLIC_ANTHROPIC_API_KEY=your-key-here
