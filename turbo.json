{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "NODE_ENV",
    "CI",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_CONNECTION_HEALTH",
    "NEXT_PUBLIC_E2E_BYPASS_AUTH",
    "NEXT_PUBLIC_BILLING_CHECKOUT_URL",
    "NEXT_PUBLIC_BILLING_PORTAL_URL",
    "NEXT_PUBLIC_PLAN_PRICE_LABELS",
    "NEXT_PUBLIC_PRODUCT_NAME",
    "NEXT_PUBLIC_SUPPORT_EMAIL",
    "NEXT_PUBLIC_TERMS_URL",
    "NEXT_PUBLIC_PRIVACY_URL",
    "NEXT_PUBLIC_BOOKING_URL",
    "NEXT_PUBLIC_APP_URL",
    "CLERK_REQUIRE_ACTIVE_SUBSCRIPTION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {},
    "test": {
      "passThroughEnv": [
        "HOME",
        "USERPROFILE",
        "PLAYWRIGHT_BROWSERS_PATH",
        "XDG_CACHE_HOME"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:clean": {
      "cache": false,
      "persistent": true
    },
    "type-check": {}
  }
}
