{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {},
    "test": {
      "passThroughEnv": [
        "HOME",
        "USERPROFILE",
        "PLAYWRIGHT_BROWSERS_PATH",
        "XDG_CACHE_HOME"
      ]
    },
    "dev": {
      "cache": false
    }
  }
}
