# Baseline environment variables
# Copy this file to .env and fill in real values.
API_GATEWAY_PORT=8080
MODEL_SERVICE_PORT=8001
WORKER_POLL_SECONDS=5
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_AUDIENCE=
# Optional override: JSON array on one line. When set, this list replaces the defaults in config.py — include every
# origin your browser will use (production Vercel, localhost, preview URLs if you do not rely on allow_origin_regex).
# Railway example:
# CORS_ORIGINS=["https://doubow.vercel.app","http://localhost:3000"]
# Vercel branch previews (*.vercel.app) are still allowed by allow_origin_regex in api_gateway/main.py unless you change it.

# Postgres (required at startup). Default in config.py uses localhost:5433 — matches ``backend/infra/docker-compose.yml``.
# DATABASE_URL=postgresql+asyncpg://doubow:doubow@localhost:5433/doubow
#
# Supabase URLs often include ?ssl=... — Makefile targets normalize DATABASE_URL for Alembic + psql (see scripts/normalize_database_url.py).
#   make -C backend db-sync

# Uploaded resume files (FastAPI). Override default ./data/resumes if needed.
# RESUME_STORAGE_DIR=./data/resumes

# Feature flag: structured resume analysis via LangChain.
# USE_LANGCHAIN=true
# Feature flag: semantic resume/job similarity blending into fit score.
# USE_SEMANTIC_MATCHING=true
# SEMANTIC_MATCHING_WEIGHT=0.25
# Optional LLM-assisted matching signal blended into final fit score.
# Requires OPENROUTER_API_KEY and uses OPENROUTER_MODEL_RESUME fallback.
# USE_LLM_JOB_MATCHING=false
# LLM_JOB_MATCHING_WEIGHT=0.20
# LLM_JOB_MATCHING_TOP_N=25
# Feature flag: route autopilot execution through LangGraph scaffold (parity mode).
# USE_LANGGRAPH_AUTOPILOT=true
# Optional debug trace logs for LangGraph autopilot node lifecycle events.
# USE_LANGGRAPH_AUTOPILOT_TRACE=true
# Optional retry budget for retryable LangGraph node failures (default: 2).
# USE_LANGGRAPH_AUTOPILOT_MAX_RETRIES=2
# Persist per-node checkpoints to autopilot_runs.graph_checkpoint for resume after worker loss (default: true).
# USE_LANGGRAPH_AUTOPILOT_CHECKPOINT=true
# Orchestrator chat transcript tail (bounds LLM context).
# ORCHESTRATOR_CHAT_TRANSCRIPT_MAX_MESSAGES=24
# ORCHESTRATOR_CHAT_TRANSCRIPT_MAX_CHARS=12000
# Classify assistant chat into account tools via LLM when keyword routing misses (default: true).
# ORCHESTRATOR_LLM_TOOL_ROUTING=true

# OpenRouter (optional but recommended for AI features).
# OPENROUTER_API_KEY=
# Defaults are tiered in config.py: qwen3-32b global, claude-sonnet chat, qwen3-8b drafts, deepseek-r1-0528 prep.
# OPENROUTER_MODEL=qwen/qwen3-32b
# OPENROUTER_MODEL_CHAT=anthropic/claude-sonnet-4.6
# OPENROUTER_MODEL_DRAFTS=qwen/qwen3-8b
# OPENROUTER_MODEL_PREP=deepseek/deepseek-r1-0528
# OPENROUTER_MODEL_RESUME=qwen/qwen3-32b
# OPENROUTER_API_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost:3000

# Adzuna provider connector (optional, for global catalog ingestion jobs).
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=gb
# ADZUNA_RESULTS_PER_PAGE=50
# ADZUNA_INGEST_HOURLY_PAGES=2
# ADZUNA_INGEST_DAILY_PAGES=5
# ADZUNA_INGEST_DEFAULT_KEYWORDS=
# ADZUNA_INGEST_DEFAULT_LOCATION=
# GREENHOUSE_BOARD_TOKENS=
# GREENHOUSE_INGEST_HOURLY_PAGES=2
# GREENHOUSE_INGEST_DAILY_PAGES=5
# GREENHOUSE_RESULTS_PER_PAGE=50
# GREENHOUSE_INGEST_DEFAULT_KEYWORDS=
# GREENHOUSE_INGEST_DEFAULT_LOCATION=
# JOB_CATALOG_INGESTION_USER_ID=catalog_ingestion_system
#
# Google Jobs vertical via SerpAPI (optional). Doubow cannot access raw Google Jobs without a licensed aggregator.
# SERPAPI_API_KEY=
# GOOGLE_JOBS_DEFAULT_QUERY=software engineer
# GOOGLE_JOBS_SERP_MAX_ROUNDS=3
# GOOGLE_JOBS_HL=en
# GOOGLE_JOBS_GL=
#
# Scrapling — optional web extraction (https://github.com/D4Vinci/Scrapling). Off by default.
# Runtime: HTTP fetch + JSON-LD JobPosting parsing (seed URLs) or optional scrapling[fetchers].
# With SCRAPLING_ENABLED=true + SCRAPLING_BUNDLE_FIXTURE=true and no fixture path, bundled sample JSON loads (local QA).
# Normalized job records can include company name and logo: map fields like logo_url / logo / thumbnail
# in your extractor; jobs.logo_url is stored. Company-only pages (about, og:image) need a separate
# template or pipeline — Scrapling is generic HTML/JS fetch + parsing, not a company database API.
#
# Local / fixture testing:
# SCRAPLING_ENABLED=true
# SCRAPLING_FIXTURE_JSON_PATH=
# SCRAPLING_BUNDLE_FIXTURE=true
# SCRAPLING_CATALOG_IN_PRESET=true
#
# Production (recommended until runtime extraction is live):
# SCRAPLING_ENABLED=false
# SCRAPLING_BUNDLE_FIXTURE=false
# SCRAPLING_CATALOG_IN_PRESET=true
# SCRAPLING_FIXTURE_JSON_PATH=
# SCRAPLING_TIMEOUT_S=60
# Runtime (no fixture): Scrapling fetches HTML and parses JSON-LD JobPosting.
# Doubow auto-links seeds to your catalog Greenhouse boards (same GREENHOUSE_BOARD_TOKENS as Greenhouse ingest):
# SCRAPLING_AUTO_GREENHOUSE_BOARD_SEEDS=true
# SCRAPLING_GREENHOUSE_SEED_JOBS_PER_BOARD=5
# Optional extra URLs (comma/newline-separated job or career pages):
# SCRAPLING_SEED_URLS=https://job-boards.greenhouse.io/yourco/jobs/123
#
# Full catalog run (API): POST /v1/jobs/providers/catalog/ingest/preset?preset=hourly|daily
# Use resume_aligned=true to derive keywords/location from the signed-in user's resume.
# Use include_legacy_connectors=true to fan out to legacy connectors (Ashby, Lever, Remotive, …) with the same query context.

# Optional: shared secret for POST /v1/webhooks/profile-impression (recruiter/ATS workers increment users.profile_views).
# PROFILE_IMPRESSION_WEBHOOK_SECRET=
# Comma-separated Clerk user ids allowed to access /v1/admin/ingestion/* in production.
# ADMIN_INGESTION_USER_IDS=user_admin_1,user_admin_2

# PostHog telemetry (optional)
# POSTHOG_HOST=https://eu.posthog.com
# POSTHOG_PROJECT_ID=
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_API_KEY=

# ─── Outbound SMTP (Doubow api_gateway — approval send, email channel) ─────
# Loaded via docker-compose env_file when using backend/.env. Also set these in repo-root .env if you run uvicorn from api_gateway without Docker.
# SMTP_ENABLED=true requires OUTBOUND_FROM_EMAIL. Leave false for dry-run (logs only).
# SMTP_ENABLED=false
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=
# SMTP_PASSWORD=
# OUTBOUND_FROM_EMAIL=
# OUTBOUND_SEND_RECIPIENT_OVERRIDE=
# Durability defaults: in production, send/autopilot use Celery unless explicitly disabled.
# USE_CELERY_FOR_SEND=true
# USE_CELERY_FOR_AUTOPILOT=true
# Emergency escape hatch only (production): allow FastAPI BackgroundTasks fallback.
# ALLOW_INPROCESS_BACKGROUND_IN_PRODUCTION=false
# After approval (email channel): ``draft`` = save in Gmail Drafts first; ``send`` = send immediately.
# GMAIL_APPROVAL_HANDOFF=draft

# ─── Google OAuth / Gmail API (Doubow api_gateway — optional Gmail send path) ─
# OAuth requests gmail.send + gmail.compose (drafts in your mailbox). Re-authorize after upgrading.
# Requires OAuth client type "Web" and authorized redirect URI matching GOOGLE_OAUTH_REDIRECT_URI.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/v1/integrations/google/callback
# GOOGLE_OAUTH_FRONTEND_REDIRECT_URI=http://localhost:3000/settings
# GOOGLE_OAUTH_STATE_SECRET=
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# GOOGLE_OAUTH_TOKEN_FERNET_KEY=
#
# ─── LinkedIn OAuth (optional LinkedIn note handoff path) ─────────────────────
# LINKEDIN_OAUTH_CLIENT_ID=
# LINKEDIN_OAUTH_CLIENT_SECRET=
# LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:8080/v1/integrations/linkedin/callback
# LINKEDIN_OAUTH_FRONTEND_REDIRECT_URI=http://localhost:3000/settings
# LINKEDIN_OAUTH_STATE_SECRET=
# Optional provider-specific token key. If omitted, backend falls back to GOOGLE_OAUTH_TOKEN_FERNET_KEY.
# LINKEDIN_OAUTH_TOKEN_FERNET_KEY=
#
# ─── Portal scanner safety ─────────────────────────────────────────────────────
# Keep false in production. Prevents SSRF to localhost/private ranges.
# PORTAL_SCANNER_ALLOW_PRIVATE_IPS=false
