NEXT_PUBLIC_API_URL=http://localhost:8000
# Vercel / production: point the web app at your deployed API (no trailing slash), e.g.
# NEXT_PUBLIC_API_URL=https://doubow-production.up.railway.app
# Frontend-only: stub all /v1/* in the browser during local `next dev` only (ignored in production builds).
# NEXT_PUBLIC_USE_MOCK_API=true
# Optional: show API health panel in dashboard sidebar when not in NODE_ENV=development
# NEXT_PUBLIC_CONNECTION_HEALTH=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Direct Anthropic API (native SDK / non-OpenRouter paths)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenRouter (optional; server-only — never NEXT_PUBLIC_* or commit real values)
# OPENROUTER_API_KEY=
# Slugs: `provider/model` — https://openrouter.ai/models
# Code defaults (backend/api_gateway/config.py): OPENROUTER_MODEL=qwen/qwen3-32b, CHAT=claude-sonnet-4.6,
# DRAFTS=qwen/qwen3-8b, PREP=deepseek-r1-0528, RESUME falls back to OPENROUTER_MODEL. Uncomment to override:
# OPENROUTER_MODEL=qwen/qwen3-32b
# OPENROUTER_MODEL_CHAT=anthropic/claude-sonnet-4.6
# OPENROUTER_MODEL_DRAFTS=qwen/qwen3-8b
# OPENROUTER_MODEL_PREP=deepseek/deepseek-r1-0528
# OPENROUTER_MODEL_RESUME=qwen/qwen3-32b
OPENROUTER_API_URL=https://openrouter.ai/api/v1
# Adzuna connector (optional, used by provider ingestion worker/cron).
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=gb
# ADZUNA_RESULTS_PER_PAGE=50
# ADZUNA_INGEST_HOURLY_PAGES=2
# ADZUNA_INGEST_DAILY_PAGES=5
# ADZUNA_INGEST_DEFAULT_KEYWORDS=
# ADZUNA_INGEST_DEFAULT_LOCATION=
# GREENHOUSE_BOARD_TOKENS=
# JOB_CATALOG_INGESTION_USER_ID=catalog_ingestion_system
# Feature flag: structured resume analysis via LangChain.
# USE_LANGCHAIN=true
# Optional LLM-assisted matching signal blended into final fit score.
# Requires OPENROUTER_API_KEY and uses OPENROUTER_MODEL_RESUME fallback.
# USE_LLM_JOB_MATCHING=false
# LLM_JOB_MATCHING_WEIGHT=0.20
# LLM_JOB_MATCHING_TOP_N=25
# Feature flag: route autopilot execution through LangGraph scaffold (parity mode).
# USE_LANGGRAPH_AUTOPILOT=true
# Optional debug trace logs for LangGraph autopilot node lifecycle events.
# USE_LANGGRAPH_AUTOPILOT_TRACE=true
# Optional retry budget for retryable LangGraph node failures (default: 2).
# USE_LANGGRAPH_AUTOPILOT_MAX_RETRIES=2
# USE_LANGGRAPH_AUTOPILOT_CHECKPOINT=true
# ORCHESTRATOR_CHAT_TRANSCRIPT_MAX_MESSAGES=24
# ORCHESTRATOR_CHAT_TRANSCRIPT_MAX_CHARS=12000

# FastAPI (asyncpg). Local Docker Postgres: from repo root run ``docker compose -f backend/infra/docker-compose.yml up -d``
# (from ``backend/`` folder use ``infra/docker-compose.yml``, not ``backend/infra/...``). Maps host port 5433.
# For Supabase use the pooled or direct Postgres URI from the dashboard; often append ?sslmode=require
# Row-level security uses session GUC app.current_user_id (set automatically per request). To enforce RLS
# at the database, connect with a role that is not PostgreSQL superuser (superuser bypasses RLS).
DATABASE_URL=postgresql+asyncpg://doubow:doubow@localhost:5433/doubow

# Optional: migrations only. When set, Alembic uses this instead of DATABASE_URL (same DB; sync driver is applied automatically).
# From Supabase: Settings → Database → Connection string → URI (direct session mode works with Alembic).
# ALEMBIC_DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres?sslmode=require

# Clerk JWT verification (production). Issuer is typically https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_ISSUER=
CLERK_AUDIENCE=
# Frontend middleware (optional): require paid/active publicMetadata for /discover, /pipeline, etc.
# CLERK_REQUIRE_ACTIVE_SUBSCRIPTION=true
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Outbound SMTP (approval emails after user approves an email-channel draft) ────────────────
# Real send requires SMTP_ENABLED=true AND OUTBOUND_FROM_EMAIL set. Otherwise the API dry-runs (logs only).
# Typical: port 587 + SMTP_USE_TLS=true, or port 465 + SMTP_USE_SSL=true and SMTP_USE_TLS=false.
# SMTP_USER / SMTP_PASSWORD = provider credentials (e.g. SendGrid often uses user "apikey").
# OUTBOUND_SEND_RECIPIENT_OVERRIDE = optional; force all sends to one inbox while testing.
# SMTP_ENABLED=false
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=
# SMTP_PASSWORD=
# OUTBOUND_FROM_EMAIL=noreply@your-verified-domain.com
# OUTBOUND_SEND_RECIPIENT_OVERRIDE=
# USE_CELERY_FOR_SEND=false

# Gmail API (FastAPI api_gateway) — connect user Google account for sending approved drafts. Distinct from
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET if you use those for NextAuth. Register Web client redirect
# GOOGLE_OAUTH_REDIRECT_URI in Google Cloud (e.g. http://localhost:8000/v1/integrations/google/callback).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/integrations/google/callback
# GOOGLE_OAUTH_FRONTEND_REDIRECT_URI=http://localhost:3000/settings
# GOOGLE_OAUTH_STATE_SECRET=
# GOOGLE_OAUTH_TOKEN_FERNET_KEY=
# LINKEDIN_OAUTH_TOKEN_FERNET_KEY=
# Gmail after approve: draft (default) vs send — see backend/.env.example GMAIL_APPROVAL_HANDOFF

# API gateway: local directory for uploaded resume files (relative paths resolved from api_gateway cwd).
# RESUME_STORAGE_DIR=./data/resumes

# Optional: Subscription page (`/billing`) — Clerk Billing or Stripe Checkout / Customer Portal URLs
# NEXT_PUBLIC_BILLING_CHECKOUT_URL=/billing/checkout
# NEXT_PUBLIC_BILLING_PORTAL_URL=/billing/portal
# Comma-separated Clerk user ids allowed to access /v1/admin/ingestion/* in production.
# ADMIN_INGESTION_USER_IDS=user_admin_1,user_admin_2

# PostHog (frontend + backend)
# Frontend capture key (Project API key):
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# Backend server-side capture/query:
# POSTHOG_HOST=https://eu.posthog.com
# POSTHOG_PROJECT_ID=
# POSTHOG_PROJECT_API_KEY=phc_xxx
# POSTHOG_PERSONAL_API_KEY=phx_xxx
