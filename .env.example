NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# FastAPI (asyncpg). For Supabase use the pooled or direct Postgres URI from the dashboard; often append ?sslmode=require
DATABASE_URL=postgresql+asyncpg://doubow:doubow@localhost:5432/doubow

# Optional: migrations only. When set, Alembic uses this instead of DATABASE_URL (same DB; sync driver is applied automatically).
# From Supabase: Settings → Database → Connection string → URI (direct session mode works with Alembic).
# ALEMBIC_DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres?sslmode=require

# Clerk JWT verification (production). Issuer is typically https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_ISSUER=
CLERK_AUDIENCE=
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# API gateway: local directory for uploaded resume files (relative paths resolved from api_gateway cwd).
# RESUME_STORAGE_DIR=./data/resumes
